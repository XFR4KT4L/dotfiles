{
  "layer": "top",
  "position": "top",
  "height": 40,
  "spacing": 4,
  "margin-top": 6,
  "margin-left": 10,
  "margin-right": 10,

  "modules-left":   ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["clock"],
  "modules-right":  ["pulseaudio", "network", "memory", "cpu", "temperature", "tray", "custom/power"],

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "1": "󰲠", "2": "󰲢", "3": "󰲤", "4": "󰲦", "5": "󰲨",
      "6": "󰲪", "7": "󰲬", "8": "󰲮", "9": "󰲰",
      "urgent": "", "active": "", "default": ""
    },
    "persistent-workspaces": { "*": 9 },
    "on-scroll-up":   "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1"
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "separate-outputs": true
  },

  "clock": {
    "format": "  {:%H:%M}",
    "format-alt": "  {:%A, %d %B %Y}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
  },

  "cpu": {
    "format": "󰍛 {usage}%",
    "tooltip": false,
    "interval": 2,
    "on-click": "kitty -e btop"
  },

  "memory": {
    "format": "󰾆 {percentage}%",
    "tooltip-format": "Usado: {used:0.1f}GB / {total:0.1f}GB",
    "interval": 3,
    "on-click": "kitty -e btop"
  },

  "temperature": {
    "critical-threshold": 85,
    "format": "{icon} {temperatureC}°C",
    "format-icons": ["", "", "", "", ""]
  },

  "network": {
    "format-wifi":       "󰤨 {essid}",
    "format-ethernet":   "󰈀 Ethernet",
    "format-disconnected":"󰤭 Sin red",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}",
    "tooltip-format-ethernet": "{ipaddr}",
    "on-click": "nm-connection-editor"
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟 Muted",
    "format-icons": {
      "headphone": "󰋋",
      "default": ["󰕿", "󰖀", "󰕾"]
    },
    "on-click": "pavucontrol",
    "scroll-step": 5
  },

  "tray": {
    "spacing": 8,
    "icon-size": 16
  },

  "custom/power": {
    "format": "⏻",
    "on-click": "wlogout --protocol layer-shell",
    "tooltip": false
  }
}
